---
import '../styles/global.css'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import Cookies from '../components/Cookies.jsx'

interface Props {
  title?: string
  description?: string
  canonical?: string
}

const {
  title = 'FisioClinic Murcia Centro - Fisioterapia, Osteopatía y Pilates',
  description = 'Centro de fisioterapia en Murcia centro, Av. Príncipe de Asturias 3, cerca del Zigzag. Fisioterapia personalizada, osteopatía, ecografía musculoesquelética y pilates Reformer. ¡Reserva cita!',
  canonical = 'https://www.fisioclinicmurcia.com/',
} = Astro.props
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#00594C" />
    <meta name="msapplication-TileColor" content="#00594C" />
    <link rel="canonical" href={canonical} />

    <!-- Google Fonts: Inter (cuerpo) + Fraunces (display) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- DNS prefetch y preconnect para Google Maps (se usa en la sección de ubicación) -->
    <link rel="dns-prefetch" href="https://maps.googleapis.com" />
    <link rel="dns-prefetch" href="https://maps.gstatic.com" />
    <link rel="preconnect" href="https://maps.googleapis.com" crossorigin />
    <link rel="preconnect" href="https://maps.gstatic.com" crossorigin />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="fisioterapia murcia centro, fisioterapeuta murcia, osteopata murcia, pilates reformer murcia, ecografia musculoesqueletica murcia, fisioterapia principe de asturias murcia, fisio cerca zigzag murcia, rehabilitacion murcia, dolor espalda murcia, hernia discal murcia"
    />
    <meta name="author" content="FisioClinic Murcia" />
    <meta name="robots" content="index, follow" />
    <meta name="geo.region" content="ES-MU" />
    <meta name="geo.placename" content="Murcia" />
    <meta name="geo.position" content="38.012589;-1.139888" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content="FisioClinic Murcia Centro - Fisioterapia y Osteopatía en Av. Príncipe de Asturias" />
    <meta
      property="og:description"
      content="Centro de fisioterapia en Murcia centro, Av. Príncipe de Asturias 3, cerca del Zigzag. Fisioterapia personalizada, osteopatía, ecografía y pilates Reformer. ¡Reserva cita!"
    />
    <meta property="og:image" content="https://www.fisioclinicmurcia.com/og-image.png" />
    <meta property="og:locale" content="es_ES" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonical} />
    <meta property="twitter:title" content="FisioClinic Murcia Centro - Fisioterapia y Osteopatía" />
    <meta
      property="twitter:description"
      content="Centro de fisioterapia en Murcia centro, Av. Príncipe de Asturias 3, cerca del Zigzag. Fisioterapia personalizada, osteopatía, ecografía y pilates Reformer."
    />
    <meta property="twitter:image" content="https://www.fisioclinicmurcia.com/og-image.png" />

    <!-- JSON-LD Structured Data -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Physiotherapy',
        name: 'FisioClinic Murcia',
        alternateName: 'FisioClinic Murcia Centro',
        description:
          'Centro de fisioterapia en Murcia centro especializado en fisioterapia personalizada, osteopatía, ecografía musculoesquelética y pilates terapéutico con Reformer.',
        image: 'https://www.fisioclinicmurcia.com/og-image.png',
        logo: 'https://www.fisioclinicmurcia.com/android-chrome-512x512.png',
        '@id': 'https://www.fisioclinicmurcia.com/#organization',
        url: 'https://www.fisioclinicmurcia.com/',
        telephone: '+34684708394',
        priceRange: '€€',
        currenciesAccepted: 'EUR',
        paymentAccepted: 'Efectivo, Tarjeta de crédito, Bizum',
        address: {
          '@type': 'PostalAddress',
          streetAddress: 'Av. Príncipe de Asturias, 3',
          addressLocality: 'Murcia',
          addressRegion: 'Región de Murcia',
          postalCode: '30007',
          addressCountry: 'ES',
        },
        geo: { '@type': 'GeoCoordinates', latitude: 38.0125899, longitude: -1.1398889 },
        areaServed: { '@type': 'City', name: 'Murcia' },
        hasMap: 'https://maps.google.com/?q=38.0125899,-1.1398889',
        openingHoursSpecification: {
          '@type': 'OpeningHoursSpecification',
          dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
          opens: '09:00',
          closes: '21:00',
        },
        medicalSpecialty: ['Fisioterapia', 'Osteopatía', 'Rehabilitación'],
        availableService: [
          { '@type': 'MedicalTherapy', name: 'Fisioterapia Personalizada', url: 'https://www.fisioclinicmurcia.com/fisioterapia-personalizada' },
          { '@type': 'MedicalTherapy', name: 'Osteopatía', url: 'https://www.fisioclinicmurcia.com/osteopatia' },
          { '@type': 'MedicalTherapy', name: 'Ecografía Musculoesquelética', url: 'https://www.fisioclinicmurcia.com/ecografia-musculoesqueletica' },
          { '@type': 'MedicalTherapy', name: 'Pilates Terapéutico Reformer', url: 'https://www.fisioclinicmurcia.com/pilates-terapeutico' },
        ],
        sameAs: ['https://www.instagram.com/fisioclinicmurcia'],
      })}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: 'FisioClinic Murcia',
        url: 'https://www.fisioclinicmurcia.com/',
        inLanguage: 'es',
      })}
    />
  </head>
  <body>
    <div class="scroll-progress" id="scroll-progress" aria-hidden="true"></div>
    <div class="min-h-screen bg-white">
      <Header />
      <main id="main-content">
        <slot />
      </main>
      <Footer />
    </div>
    <Cookies client:load />

    <script>
      // Scroll-reveal global (IntersectionObserver, respeta reduced-motion)
      const reveals = document.querySelectorAll('[data-reveal]')
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        reveals.forEach((el) => el.classList.add('is-visible'))
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible')
                io.unobserve(entry.target)
              }
            })
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
        )
        reveals.forEach((el) => io.observe(el))
      }

      // Barra de progreso de lectura
      const bar = document.getElementById('scroll-progress')
      if (bar) {
        let ticking = false
        const update = () => {
          const h = document.documentElement
          const max = h.scrollHeight - h.clientHeight
          const p = max > 0 ? h.scrollTop / max : 0
          bar.style.setProperty('--progress', p.toFixed(4))
          ticking = false
        }
        const onScroll = () => {
          if (!ticking) {
            ticking = true
            requestAnimationFrame(update)
          }
        }
        window.addEventListener('scroll', onScroll, { passive: true })
        window.addEventListener('resize', onScroll, { passive: true })
        update()
      }
    </script>
  </body>
</html>
