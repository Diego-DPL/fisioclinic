        </div>

        <div class="grid lg:grid-cols-2 gap-12">
          <ContactForm client:visible />

          <div class="space-y-6 lg:pt-2">
            <h3 class="text-2xl font-bold text-green-principal">Información de contacto</h3>
            <div class="space-y-4">
              {contactInfo.map(({ icon, label, value, href }) => {
                const Icon = icon
                return (
                  <div class="flex items-center gap-4 p-4 rounded-2xl bg-gray-50 border border-gray-100">
                    <div class="w-11 h-11 bg-green-secundario/20 rounded-xl flex items-center justify-center flex-shrink-0">
                      <Icon className="w-5 h-5 text-green-principal" />
                    </div>
                    <div>
                      <p class="text-xs text-gray-400 font-medium uppercase tracking-wide">{label}</p>
                      {href ? (
                        <a href={href} class="font-semibold text-gray-800 hover:text-green-principal transition-colors text-sm">{value}</a>
                      ) : (
                        <p class="font-semibold text-gray-800 text-sm">{value}</p>
                      )}
                    </div>
                  </div>
                )
              })}
            </div>

            <div class="bg-gradient-to-br from-green-principal to-green-principal/90 p-6 rounded-2xl text-white">
              <h4 class="font-bold mb-3 text-lg">¿Por qué elegirnos?</h4>
              <ul class="space-y-2.5">
                {whyChooseUs.map((item) => (
                  <li class="flex items-center gap-2 text-sm text-white/90">
                    <CheckCircle className="w-4 h-4 text-green-claro flex-shrink-0" />
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Mapa: carga diferida al acercarse al viewport (igual que el comportamiento original)
  const mapContainer = document.querySelector('[data-map]')
  if (mapContainer) {
    const io = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          mapContainer.innerHTML =
            '<iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3143.483987479918!2d-1.139888923679808!3d38.01258997192661!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd6381c60718c38b%3A0x7c9b8b6b1b1b1b1b!2sAv.%20Pr%C3%ADncipe%20de%20Asturias%2C%203%2C%2030007%20Murcia!5e0!3m2!1ses!2ses!4v1620000000000" width="100%" height="450" style="border:0" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Ubicación de FisioClinic"></iframe>'
          io.disconnect()
        }
      },
      { rootMargin: '200px' }
    )
    io.observe(mapContainer)
  }

  // Fichas del equipo: abrir/cerrar en móvil (en desktop se usa hover por CSS)
  document.querySelectorAll('[data-team-card]').forEach((card) => {
    const overlay = card.querySelector('.team-overlay')
    const openBtn = card.querySelector('[data-team-open]')
    const closeBtn = card.querySelector('[data-team-close]')
    openBtn?.addEventListener('click', () => overlay?.classList.add('is-open'))
    closeBtn?.addEventListener('click', (e) => {
      e.stopPropagation()
      overlay?.classList.remove('is-open')
    })
    overlay?.addEventListener('click', (e) => {
      if (e.target === overlay) overlay.classList.remove('is-open')
    })
  })
</script>
